# Neo4j connection — matches docker-compose.yml defaults
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password123
NEO4J_DATABASE=neo4j

# ── OpenAI (optional) ──────────────────────────────────────────────────────────
# Leave OPENAI_API_KEY empty to run in Demo Mode — mock embeddings, no API calls, no cost.
#
# To enable OpenAI Mode (text-embedding-3-small + gpt-4o):
#   1. Set OPENAI_API_KEY to your key.
#   2. Start the server and select OpenAI Mode in the browser UI, or pass
#      "mode": "openai" in the API request body.
#   The server re-indexes embeddings automatically on the first OpenAI Mode request —
#   no manual seed command required after the initial setup.

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o
